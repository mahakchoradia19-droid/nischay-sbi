# Optional — enables the LIVE path (Claude plans + calls the tools itself).
# Without this, the demo runs an offline deterministic agent with identical behaviour.
#
#   export ANTHROPIC_API_KEY=sk-ant-...
#   python3 app.py
#
ANTHROPIC_API_KEY=
# Override the model (defaults to claude-opus-4-8)
# YONO_MODEL=claude-opus-4-8
# PORT=8000
